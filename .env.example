# ============================================================================
# ALERT SYSTEM CONFIGURATION - TEMPLATE
# Copy this file to .env and fill in your actual values
# ============================================================================

# --- Runtime Configuration ---
DRY_RUN=True
DRY_RUN_EMAIL=user@email.com,user2@email.com
RUN_ONCE=False

# --- Database Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASS=your_password

# --- SSH Tunnel Configuration (optional) ---
USE_SSH_TUNNEL=False
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_KEY_PATH=

# --- SMTP Email Configuration ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# --- Email Recipients ---
INTERNAL_RECIPIENTS=admin@company.com

# Company-specific TO recipients (leave empty for pending invoices alert)
PROMINENCE_EMAIL_TO_RECIPIENTS=
SEATRADERS_EMAIL_TO_RECIPIENTS=

# Company-specific CC recipients
PROMINENCE_EMAIL_CC_RECIPIENTS=user1@prominencemaritime.com,user2@prominencemaritime.com
SEATRADERS_EMAIL_CC_RECIPIENTS=

# --- Feature Flags ---
ENABLE_EMAIL_ALERTS=True
ENABLE_TEAMS_ALERTS=False
ENABLE_SPECIAL_TEAMS_EMAIL_ALERT=False
SPECIAL_TEAMS_EMAIL=

# --- Company Branding ---
PROMINENCE_LOGO=trans_logo_prominence_procreate_small.png
SEATRADERS_LOGO=trans_logo_seatraders_procreate_small.png

# --- URLs ---
ENABLE_LINKS=True
BASE_URL=https://prominence.orca.tools
URL_PATH=/invoices

# --- Scheduling ---
SCHEDULE_FREQUENCY_HOURS=
# 12:00,18:00
SCHEDULE_TIMES=12:00
# isoweekday: 1=Monday, 2=Tuesday, ..., 7=Sunday
SCHEDULE_DAYS=1
SCHEDULE_TIMES_TIMEZONE=Europe/Athens
TIMEZONE=UTC

# --- Tracking & Reminders ---
REMINDER_FREQUENCY_DAYS=
SENT_EVENTS_FILE=sent_alerts.json
RESEND_EVENTS_ON=True

# --- SQL Query Files --
SQL_QUERY_FILE=PendingInvoices.sql

# --- Alert-Specific ---
LOOKBACK_DAYS=730
INCLUDE_GREY_METADATA_SECTION=True

# --- Logging ---
LOG_FILE=alerts.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# --- User Permissions ---
# echo UID=$(id -u) and echo GID=$(id -g)
UID=1000
GID=1000
